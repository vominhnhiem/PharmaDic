@inherits LayoutComponentBase
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager

<div class="bg-background text-on-background min-h-screen flex">
    @* --- SIDEBAR PANEL --- *@
    <aside class="w-64 h-screen fixed left-0 top-0 bg-surface border-r border-border flex flex-col py-6 z-50">
        <div class="px-6 mb-8">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded bg-primary flex items-center justify-center">
                    <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                </div>
                <div>
                    <h1 class="font-headline-sm text-headline-sm font-bold text-primary">PharmaCheck</h1>
                    <p class="font-label-md text-on-surface-variant">Admin Portal</p>
                </div>
            </div>
        </div>

        <nav class="flex-1 space-y-1 flex flex-col">
            <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                <span class="material-symbols-outlined">dashboard</span>
                <span>Tổng quan</span>
            </NavLink>

            <NavLink class="nav-item" href="/medications">
                <span class="material-symbols-outlined">medication</span>
                <span>Quản lý thuốc</span>
            </NavLink>

            <NavLink class="nav-item" href="/categories">
                <span class="material-symbols-outlined">category</span>
                <span>Danh mục thuốc</span>
            </NavLink>

            <NavLink class="nav-item" href="/symptoms">
                <span class="material-symbols-outlined">clinical_notes</span>
                <span>Nhật ký triệu chứng</span>
            </NavLink>

            <NavLink class="nav-item" href="/users">
                <span class="material-symbols-outlined">group</span>
                <span>Người dùng</span>
            </NavLink>

            @* NÚT ĐĂNG NHẬP / ĐĂNG XUẤT ĐỘNG *@
            <div class="mt-auto pt-4 border-t border-border px-4">
                @if (isLoggedIn)
                {
                    <button @onclick="HandleLogout" class="nav-item text-error hover:bg-error-container w-full text-left rounded-md transition-colors">
                        <span class="material-symbols-outlined">logout</span>
                        <span>Đăng xuất</span>
                    </button>
                }
                else
                {
                    <a href="/login" class="nav-item text-primary hover:bg-primary/10 w-full text-left rounded-md transition-colors decoration-none">
                        <span class="material-symbols-outlined">login</span>
                        <span>Đăng nhập</span>
                    </a>
                }
            </div>
        </nav>
    </aside>

    @* --- TOP NAVBAR --- *@
    <header class="fixed top-0 right-0 left-64 h-16 z-40 bg-surface/80 backdrop-blur-md border-b border-border flex justify-between items-center px-8">
        <div class="flex items-center bg-surface-container-low px-4 py-2 rounded-lg w-96 transition-shadow focus-within:shadow-sm focus-within:ring-1 focus-within:ring-primary">
            <span class="material-symbols-outlined text-on-surface-variant mr-2">search</span>
            <input class="bg-transparent border-none outline-none focus:ring-0 text-body-md w-full" placeholder="Tìm kiếm nhanh..." type="text">
        </div>

        <div class="flex items-center gap-4 cursor-pointer hover:bg-surface-container-low p-2 rounded-lg transition-colors">
            <div class="text-right">
                <p class="font-label-md font-bold text-primary">Admin User</p>
                <p class="text-[10px] text-on-surface-variant uppercase">Hệ thống cấp cao</p>
            </div>
            <img alt="Avatar" class="w-10 h-10 rounded-full border-2 border-primary/20" src="https://ui-avatars.com/api/?name=Admin&background=random">
        </div>
    </header>

    @* --- MAIN CONTENT --- *@
    <main class="ml-64 pt-16 w-full min-h-screen bg-surface-container-lowest/30">
        <div class="p-8 max-w-[1440px] mx-auto">
            <ErrorBoundary>
                <ChildContent>
                    @Body
                </ChildContent>
                <ErrorContent Context="Exception">
                    <div class="bg-error-container text-on-error-container p-6 rounded-lg shadow-sm border border-error/20">
                        <div class="flex items-center gap-3 mb-2">
                            <span class="material-symbols-outlined text-error text-2xl">error</span>
                            <h3 class="text-lg font-bold">Đã xảy ra lỗi khi tải trang này</h3>
                        </div>
                        <p class="text-sm opacity-80 mb-4">Vui lòng tải lại trang hoặc liên hệ quản trị viên.</p>
                        <details class="text-xs bg-white/50 p-4 rounded whitespace-pre-wrap font-mono">
                            <summary class="cursor-pointer font-bold mb-2">Xem chi tiết lỗi</summary>
                            @Exception.Message
                        </details>
                    </div>
                </ErrorContent>
            </ErrorBoundary>
        </div>
    </main>
</div>

<style>
    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 24px;
        color: var(--sys-on-surface-variant, #49454F);
        transition: all 0.2s ease-in-out;
        text-decoration: none;
    }

        .nav-item:hover {
            background-color: var(--sys-surface-container, #F3EDF7);
            color: var(--sys-on-surface, #1D1B20);
        }

        .nav-item.active {
            color: var(--sys-primary, #6750A4);
            background-color: var(--sys-secondary-container, #E8DEF8);
            border-right: 4px solid var(--sys-primary, #6750A4);
            font-weight: 600;
        }
</style>

@code {
    private bool isLoggedIn = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            var isLoginPage = NavigationManager.Uri.EndsWith("/login");

            if (!string.IsNullOrEmpty(token))
            {
                isLoggedIn = true;
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
                StateHasChanged();

                if (isLoginPage)
                {
                    NavigationManager.NavigateTo("/");
                }
            }
            else
            {
                isLoggedIn = false;
                StateHasChanged();

                if (!isLoginPage)
                {
                    NavigationManager.NavigateTo("/login");
                }
            }
        }
    }

    private async Task HandleLogout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "authToken");
        Http.DefaultRequestHeaders.Authorization = null;
        isLoggedIn = false;
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}