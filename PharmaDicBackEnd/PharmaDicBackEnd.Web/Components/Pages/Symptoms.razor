@page "/symptoms"

@* --- TIÊU ĐỀ TRANG & NÚT TÁC VỤ --- *@
<div class="flex flex-col lg:flex-row lg:items-end justify-between gap-4 mb-6">
    <div>
        <h3 class="text-3xl font-bold text-on-surface mb-1">Nhật ký triệu chứng</h3>
        <p class="text-base text-on-surface-variant">Theo dõi và thẩm định các phản hồi tự động từ hệ thống AI.</p>
    </div>
    <div class="flex gap-3 justify-end">
        <button class="flex items-center gap-2 px-4 py-2 border border-border bg-surface hover:bg-surface-container-low rounded-lg transition-all text-sm font-medium">
            <span class="material-symbols-outlined text-[20px]">download</span>
            Xuất báo cáo
        </button>
        <button @onclick="RefreshData" class="flex items-center gap-2 px-4 py-2 bg-primary text-white hover:bg-[#005049] rounded-lg transition-all text-sm font-medium shadow-sm active:scale-95">
            <span class="material-symbols-outlined text-[20px]">refresh</span>
            Cập nhật dữ liệu
        </button>
    </div>
</div>

@* --- BENTO STATS GRID --- *@
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
    <div class="p-6 bg-surface border border-border rounded-xl shadow-sm border-l-4 border-l-primary">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1">Tổng ghi chép</p>
        <h4 class="text-2xl font-bold text-on-surface">1,284</h4>
        <span class="text-xs text-success flex items-center gap-1 mt-2 font-medium">
            <span class="material-symbols-outlined text-[16px]">trending_up</span> +12% tháng này
        </span>
    </div>
    <div class="p-6 bg-surface border border-border rounded-xl shadow-sm border-l-4 border-l-warning">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-1">Chờ thẩm định</p>
        <h4 class="text-2xl font-bold text-on-surface">42</h4>
        <span class="text-xs text-on-surface-variant flex items-center gap-1 mt-2">
            Cần xử lý ngay trong ngày
        </span>
    </div>
    <div class="p-6 bg-surface border border-border rounded-xl shadow-sm border-l-4 border-l-success">
        <p class="text-xs font-semibold text-on-surface-variant tracking-wider mb-1">Tỷ lệ AI chính xác</p>
        <h4 class="text-2xl font-bold text-on-surface">94.2%</h4>
        <span class="text-xs text-success flex items-center gap-1 mt-2 font-medium">
            Vượt mục tiêu 2.1%
        </span>
    </div>
    <div class="p-6 bg-surface border border-border rounded-xl shadow-sm border-l-4 border-l-tertiary">
        <p class="text-xs font-semibold text-on-surface-variant tracking-wider mb-1">Triệu chứng phổ biến</p>
        <h4 class="text-2xl font-bold text-on-surface">Đau đầu</h4>
        <span class="text-xs text-on-surface-variant flex items-center gap-1 mt-2">
            Chiếm 24% tổng số ca
        </span>
    </div>
</div>

@* --- BẢNG DỮ LIỆU & BỘ LỌC --- *@
<section class="bg-surface border border-border rounded-xl shadow-sm overflow-hidden mb-8">
    @* Thanh công cụ bộ lọc *@
    <div class="px-6 py-4 border-b border-border flex flex-wrap justify-between items-center bg-gray-50/50 gap-4">
        <div class="flex gap-1 p-1 bg-gray-100 border border-border rounded-lg">
            <button @onclick='() => ChangeFilter("all")' class="px-4 py-1.5 text-xs font-semibold rounded-md transition-all @(ActiveFilter == "all" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">Tất cả</button>
            <button @onclick='() => ChangeFilter("today")' class="px-4 py-1.5 text-xs font-semibold rounded-md transition-all @(ActiveFilter == "today" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">Hôm nay</button>
            <button @onclick='() => ChangeFilter("week")' class="px-4 py-1.5 text-xs font-semibold rounded-md transition-all @(ActiveFilter == "week" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">Tuần này</button>
            <button @onclick='() => ChangeFilter("month")' class="px-4 py-1.5 text-xs font-semibold rounded-md transition-all @(ActiveFilter == "month" ? "bg-white text-primary shadow-sm" : "text-on-surface-variant hover:bg-white/50")">Tháng này</button>
        </div>
        <div class="flex items-center gap-3">
            <span class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Lọc theo:</span>
            <select class="bg-white border border-border rounded-lg px-3 py-1.5 text-xs font-medium focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none">
                <option>Tất cả trạng thái</option>
                <option>Đã xác nhận</option>
                <option>Chưa xác nhận</option>
                <option>Sai lệch</option>
            </select>
        </div>
    </div>

    @* Vùng Render Table *@
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead class="bg-gray-50/70 border-b border-border">
                <tr>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Thời gian</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Người dùng</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Mô tả triệu chứng</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Gợi ý từ AI</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Độ tin cậy</th>
                    <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-center">Phản hồi</th>
                    <th class="px-6 py-4 border-b border-border w-12"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border">
                @foreach (var log in Logs)
                {
                    <tr class="hover:bg-gray-50/50 transition-all duration-200 group">
                        <td class="px-6 py-5 align-top whitespace-nowrap">
                            <p class="text-sm font-semibold text-on-surface">@log.Time</p>
                            <p class="text-xs text-on-surface-variant mt-0.5">@log.Date</p>
                        </td>
                        <td class="px-6 py-5 align-top whitespace-nowrap">
                            <div class="flex items-center gap-2.5">
                                <div class="w-8 h-8 rounded-full flex items-center justify-center font-bold text-[11px] @log.UserAvatarBg @log.UserAvatarText">
                                    @log.UserInitials
                                </div>
                                <div>
                                    <p class="text-xs font-bold text-on-surface">@log.UserName</p>
                                    <p class="text-[11px] text-on-surface-variant mt-0.5">ID: @log.UserId</p>
                                </div>
                            </div>
                        </td>
                        <td class="px-6 py-5 align-top max-w-xs">
                            <p class="text-sm text-on-surface leading-relaxed line-clamp-3 group-hover:line-clamp-none transition-all">
                                @log.Description
                            </p>
                        </td>
                        <td class="px-6 py-5 align-top whitespace-nowrap">
                            <div class="space-y-1">
                                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-primary-container text-on-primary-container">
                                    @log.AiSuggestion
                                </span>
                                <p class="text-xs text-on-surface-variant">@log.AiDosage</p>
                            </div>
                        </td>
                        <td class="px-6 py-5 align-top whitespace-nowrap">
                            <div class="flex items-center gap-2">
                                <div class="h-1.5 w-16 bg-gray-200 rounded-full overflow-hidden">
                                    <div class="@log.ConfidenceBarColor h-full" style="width: @(log.Confidence)%"></div>
                                </div>
                                <span class="text-xs font-bold @log.ConfidenceTextColor">@log.Confidence%</span>
                            </div>
                        </td>
                        <td class="px-6 py-5 align-top text-center whitespace-nowrap">
                            @if (log.Status == "Pending")
                            {
                                <div class="flex justify-center gap-2">
                                    <button @onclick='() => UpdateStatus(log, "Correct")' class="w-8 h-8 rounded-full border border-success text-success hover:bg-success hover:text-white transition-all flex items-center justify-center active:scale-90" title="Xác nhận Đúng">
                                        <span class="material-symbols-outlined text-[18px]">check</span>
                                    </button>
                                    <button @onclick='() => UpdateStatus(log, "Incorrect")' class="w-8 h-8 rounded-full border border-error text-error hover:bg-error hover:text-white transition-all flex items-center justify-center active:scale-90" title="Báo cáo Sai">
                                        <span class="material-symbols-outlined text-[18px]">close</span>
                                    </button>
                                </div>
                            }
                            else if (log.Status == "Correct")
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-success/10 text-success text-[11px] font-bold uppercase tracking-wider">
                                    <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">check_circle</span>
                                    ĐÚNG
                                </span>
                                <p class="text-[10px] text-on-surface-variant mt-1 italic">@log.FeedbackNote</p>
                            }
                            else if (log.Status == "Incorrect")
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-red-50 text-red-600 text-[11px] font-bold uppercase tracking-wider">
                                    <span class="material-symbols-outlined text-[14px]" style="font-variation-settings: 'FILL' 1;">cancel</span>
                                    SAI
                                </span>
                                <p class="text-[10px] text-on-surface-variant mt-1 italic">@log.FeedbackNote</p>
                            }
                        </td>
                        <td class="px-6 py-5 align-top text-right">
                            <button class="p-1.5 text-on-surface-variant hover:text-primary hover:bg-gray-100 rounded-lg transition-all">
                                <span class="material-symbols-outlined text-[20px]">more_vert</span>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @* Vùng phân trang (Pagination) *@
    <div class="px-6 py-4 border-t border-border flex justify-between items-center bg-gray-50/50">
        <p class="text-xs font-medium text-on-surface-variant">Hiển thị 1 - 3 trên 1,284 ghi chép</p>
        <div class="flex gap-1.5">
            <button class="p-1.5 rounded border border-border bg-white text-gray-400 hover:bg-gray-50 transition-all disabled:opacity-50" disabled>
                <span class="material-symbols-outlined text-[20px]">chevron_left</span>
            </button>
            <button class="w-8 h-8 flex items-center justify-center rounded bg-primary text-white text-xs font-bold shadow-sm">1</button>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border bg-white hover:bg-gray-50 text-xs font-semibold text-on-surface-variant transition-all">2</button>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border bg-white hover:bg-gray-50 text-xs font-semibold text-on-surface-variant transition-all">3</button>
            <button class="p-1.5 rounded border border-border bg-white text-on-surface-variant hover:bg-gray-50 transition-all">
                <span class="material-symbols-outlined text-[20px]">chevron_right</span>
            </button>
        </div>
    </div>
</section>

@* --- PHẦN PANEL CHI TIẾT PHÍA DƯỚI (BOTTOM BLOCKS) --- *@
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    @* Khối gợi ý thông minh AI *@
    <div class="bg-surface border border-border rounded-xl p-6 relative overflow-hidden shadow-sm">
        <div class="relative z-10">
            <h5 class="text-lg font-bold text-on-surface mb-4">Gợi ý AI thông minh</h5>
            <div class="space-y-4">
                <div class="flex gap-4 p-4 rounded-lg bg-gray-50 border border-border hover:border-primary/30 transition-colors">
                    <div class="w-12 h-12 bg-primary-container text-on-primary-container rounded-xl flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">psychology</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-on-surface">Phân tích xu hướng</p>
                        <p class="text-xs text-on-surface-variant leading-relaxed mt-1">Tăng 15% các ca dị ứng thời tiết trong tuần này tại khu vực Hà Nội. Đề xuất chuẩn bị sẵn kho thuốc kháng histamin.</p>
                    </div>
                </div>
                <div class="flex gap-4 p-4 rounded-lg bg-gray-50 border border-border hover:border-tertiary/30 transition-colors">
                    <div class="w-12 h-12 bg-tertiary-container text-white rounded-xl flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">verified_user</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-on-surface">Độ chính xác mô hình</p>
                        <p class="text-xs text-on-surface-variant leading-relaxed mt-1">Mô hình Symptom-v2.4 đang hoạt động ổn định với độ tin cậy trung bình 94% trên các ca tiêu hóa.</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="absolute -right-12 -bottom-12 w-48 h-48 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>
    </div>

    @* Khối hoạt động thẩm định gần đây *@
    <div class="bg-surface border border-border rounded-xl p-6 shadow-sm flex flex-col justify-between">
        <div>
            <h5 class="text-lg font-bold text-on-surface mb-4">Hoạt động thẩm định gần đây</h5>
            <div class="space-y-4">
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-success shrink-0"></div>
                    <p class="text-xs text-on-surface-variant flex-1">Dược sĩ <b class="text-on-surface font-semibold">Lê Minh</b> đã xác nhận ca #8821 là Đúng.</p>
                    <span class="text-[11px] text-gray-400">2 phút trước</span>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-error shrink-0"></div>
                    <p class="text-xs text-on-surface-variant flex-1">Dược sĩ <b class="text-on-surface font-semibold">Hoàng Thu</b> đã đánh dấu ca #9952 là Sai.</p>
                    <span class="text-[11px] text-gray-400">15 phút trước</span>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-success shrink-0"></div>
                    <p class="text-xs text-on-surface-variant flex-1">Admin <b class="text-on-surface font-semibold">Hệ thống</b> tự động xác nhận ca #1042.</p>
                    <span class="text-[11px] text-gray-400">1 giờ trước</span>
                </div>
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-warning shrink-0"></div>
                    <p class="text-xs text-on-surface-variant flex-1">Cần thêm thông tin từ người dùng cho ca #7712.</p>
                    <span class="text-[11px] text-gray-400">3 giờ trước</span>
                </div>
            </div>
        </div>
        <button class="mt-5 w-full text-center py-2 text-xs font-bold text-primary hover:underline transition-all">
            Xem tất cả nhật ký hoạt động
        </button>
    </div>
</div>

@code {
    private string ActiveFilter = "all";

    // Danh sách dữ liệu cấu trúc mẫu đổi từ HTML sang Object C#
    private List<SymptomLogModel> Logs = new()
    {
        new SymptomLogModel {
            Time = "14:20", Date = "12/10/2023", UserInitials = "NH", UserName = "Nguyễn Văn H.", UserId = "#8821",
            UserAvatarBg = "bg-secondary-container", UserAvatarText = "text-secondary",
            Description = "Đau âm ỉ vùng thượng vị, kèm theo ợ chua sau khi ăn đồ cay nóng. Cảm giác nóng rát ngực.",
            AiSuggestion = "Phosphalugel 20%", AiDosage = "Liều: 1 gói/lần, 3 lần/ngày",
            Confidence = 92, ConfidenceBarColor = "bg-success", ConfidenceTextColor = "text-success",
            Status = "Pending", FeedbackNote = ""
        },
        new SymptomLogModel {
            Time = "11:05", Date = "12/10/2023", UserInitials = "TL", UserName = "Trần Thị L.", UserId = "#1042",
            UserAvatarBg = "bg-tertiary-fixed", UserAvatarText = "text-tertiary",
            Description = "Ho khan kéo dài 3 ngày, cổ họng ngứa rát, không sốt. Đã dùng trà gừng nhưng không đỡ.",
            AiSuggestion = "Eugica", AiDosage = "Dạng viên nang mềm",
            Confidence = 78, ConfidenceBarColor = "bg-warning", ConfidenceTextColor = "text-warning",
            Status = "Correct", FeedbackNote = "Thẩm định bởi Dr. Nam"
        },
        new SymptomLogModel {
            Time = "09:45", Date = "12/10/2023", UserInitials = "PA", UserName = "Phạm Anh T.", UserId = "#9952",
            UserAvatarBg = "bg-secondary-fixed", UserAvatarText = "text-on-secondary-container",
            Description = "Sổ mũi, hắt hơi liên tục, ngứa mắt. Nghi ngờ do dị ứng phấn hoa khi đi dã ngoại.",
            AiSuggestion = "Telfast HD", AiDosage = "Fexofenadin 180mg",
            Confidence = 95, ConfidenceBarColor = "bg-success", ConfidenceTextColor = "text-success",
            Status = "Incorrect", FeedbackNote = "Cần tư vấn trực tiếp"
        }
    };

    private void ChangeFilter(string filterName)
    {
        ActiveFilter = filterName;
        // Viết thêm logic xử lý lọc dữ liệu tại đây nếu cần
    }

    private void UpdateStatus(SymptomLogModel log, string newStatus)
    {
        log.Status = newStatus;
        log.FeedbackNote = newStatus == "Correct" ? "Thẩm định bởi Bạn" : "Đã đánh dấu sai lệch";
    }

    private void RefreshData()
    {
        // Thực thi hoặc gọi lại API làm mới danh sách dữ liệu
    }

    // Lớp định nghĩa cấu trúc Log Triệu Chứng
    public class SymptomLogModel
    {
        public string Time { get; set; } = string.Empty;
        public string Date { get; set; } = string.Empty;
        public string UserInitials { get; set; } = string.Empty;
        public string UserName { get; set; } = string.Empty;
        public string UserId { get; set; } = string.Empty;
        public string UserAvatarBg { get; set; } = string.Empty;
        public string UserAvatarText { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string AiSuggestion { get; set; } = string.Empty;
        public string AiDosage { get; set; } = string.Empty;
        public int Confidence { get; set; }
        public string ConfidenceBarColor { get; set; } = "bg-primary";
        public string ConfidenceTextColor { get; set; } = "text-primary";
        public string Status { get; set; } = "Pending"; // "Pending", "Correct", "Incorrect"
        public string FeedbackNote { get; set; } = string.Empty;
    }
}