@page "/login"
@using PharmaDicBackEnd.ApiService.DTOs
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS
@rendermode InteractiveServer

<div class="min-h-screen flex flex-col items-center justify-center bg-surface-container-lowest">
    <div class="bg-white p-10 rounded-2xl shadow-sm border border-border w-full max-w-md">

        @* --- LOGO & TIÊU ĐỀ --- *@
        <div class="text-center mb-8">
            <div class="w-14 h-14 rounded-xl bg-primary flex items-center justify-center mx-auto mb-4 shadow-sm">
                <span class="material-symbols-outlined text-white text-3xl" style="font-variation-settings: 'FILL' 1;">medical_services</span>
            </div>
            <h2 class="text-2xl font-bold text-primary">PharmaCheck Admin</h2>
            <p class="text-sm text-on-surface-variant mt-1">Vui lòng đăng nhập để tiếp tục</p>
        </div>

        @* --- FORM ĐĂNG NHẬP --- *@
        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="space-y-5 mb-6">
                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-1">Tài khoản</label>
                    <InputText @bind-Value="loginModel.Email" class="w-full px-4 py-3 bg-surface-container-lowest border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Nhập tên đăng nhập..." />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-on-surface mb-1">Mật khẩu</label>
                    <InputText @bind-Value="loginModel.Password" type="password" class="w-full px-4 py-3 bg-surface-container-lowest border border-border rounded-lg focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="••••••••" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="bg-error-container text-error px-4 py-3 rounded-lg text-sm mb-6 flex items-center gap-2 font-medium">
                    <span class="material-symbols-outlined text-lg">error</span>
                    @errorMessage
                </div>
            }

            <button type="submit" disabled="@isLoading" class="w-full py-3 bg-primary text-white font-bold rounded-lg hover:bg-primary/90 disabled:opacity-50 transition-colors flex justify-center items-center gap-2 shadow-sm">
                @if (isLoading)
                {
                    <span class="material-symbols-outlined animate-spin text-sm">progress_activity</span>
                    <span>Đang xác thực...</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-sm">login</span>
                    <span>Đăng nhập hệ thống</span>
                }
            </button>
        </EditForm>
    </div>
</div>

@code {
    // 1. Sử dụng đúng mô hình dữ liệu (DTO) của bạn
    // Chú ý: Đảm bảo class LoginRequest có các trường: public string Email { get; set; } và public string Password { get; set; }
    private LoginRequest loginModel = new LoginRequest();

    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleLogin()
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // 2. Gọi API đăng nhập (POST đến api/Auth/login)
            var response = await Http.PostAsJsonAsync("api/Auth/login", loginModel);

            if (response.IsSuccessStatusCode)
            {
                // 3. Đọc dữ liệu JSON trả về và map với AuthResponse
                var result = await response.Content.ReadFromJsonAsync<AuthResponse>();

                if (result != null && !string.IsNullOrEmpty(result.Token))
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", "authToken", result.Token);
                    Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", result.Token);

                    // SỬA DÒNG NÀY: Thêm tham số forceLoad: true
                    NavigationManager.NavigateTo("/", forceLoad: true);
                }
                else
                {
                    errorMessage = "Đăng nhập thất bại: Không nhận được token từ máy chủ.";
                }
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                // Xử lý riêng cho mã lỗi 401 (sai email hoặc mật khẩu)
                errorMessage = "Email hoặc mật khẩu không chính xác!";
            }
            else
            {
                // Các lỗi khác (500, 404, v.v.)
                errorMessage = $"Đã xảy ra lỗi hệ thống (Mã: {response.StatusCode}).";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể kết nối đến máy chủ: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // 7. Tạo một class để hứng cấu trúc JSON trả về từ AuthController
    public class AuthResponse
    {
        public string Message { get; set; } = string.Empty;
        public string Token { get; set; } = string.Empty;
        public string Role { get; set; } = string.Empty;
    }
}