@page "/medications"
@using System.Net.Http.Headers
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager NavigationManager
@using PharmaDicBackEnd.ApiService.DTOs
<PageTitle>Danh sách thuốc - PharmaCheck</PageTitle>

@* --- HEADER --- *@
<div class="mb-6 flex justify-between items-end">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Danh sách thuốc</h2>
        <p class="text-sm text-gray-500 mt-1">Quản lý và cập nhật thông tin kho dược phẩm hệ thống.</p>
    </div>
    <a href="/medications/add" class="flex items-center gap-2 px-4 py-2 bg-[#00685f] text-white font-medium rounded-md hover:bg-[#00524b] transition-all text-sm shadow-sm decoration-none">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Thêm thuốc mới
    </a>
</div>

@* --- BẢNG DỮ LIỆU CHÍNH --- *@
<div class="bg-white border border-gray-200 rounded-xl shadow-sm mb-6">

    @* BỘ LỌC TÌM KIẾM & DANH MỤC ĐỘNG *@
    <div class="flex gap-4 px-6 py-4 border-b border-gray-100 bg-white rounded-t-xl">
        <div class="flex items-center bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-md w-64 focus-within:border-[#00685f] transition-colors">
            <span class="material-symbols-outlined text-gray-400 text-[18px] mr-2">filter_list</span>

            @* SỬA Ở ĐÂY: Lọc theo danh mục động lấy từ SQL Server *@
            <select @bind="SelectedCategoryId" @bind:after="OnCategoryFilterChanged" class="bg-transparent border-none outline-none text-sm w-full text-gray-600 cursor-pointer focus:ring-0">
                <option value="">Tất cả danh mục</option>
                @foreach (var cat in categoriesList)
                {
                    <option value="@cat.CategoryId">@cat.CategoryName</option>
                }
            </select>
        </div>

        
    </div>

    @if (isLoading)
    {
        <div class="flex justify-center items-center py-20">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-[#00685f]"></div>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="m-6 bg-red-50 text-red-600 p-4 rounded-md text-sm font-medium border border-red-100 flex items-center gap-2 shadow-sm">
            <span class="material-symbols-outlined">error</span> @errorMessage
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="py-16 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-50 text-gray-400 mb-4 border border-gray-100">
                <span class="material-symbols-outlined text-3xl">medication</span>
            </div>
            <h3 class="text-lg font-bold text-gray-700 mb-1">Chưa có dữ liệu</h3>
            <p class="text-gray-500 text-sm">Hệ thống hiện chưa có loại thuốc nào khớp với bộ lọc.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-gray-100 bg-gray-50/50">
                        <th class="px-6 py-4 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Tên thuốc</th>
                        <th class="px-6 py-4 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Danh mục</th>
                        <th class="px-6 py-4 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Nhà sản xuất</th>
                        @* ĐÃ XÓA CỘT TRẠNG THÁI KHO THEO YÊU CẦU *@
                        <th class="px-6 py-4 text-[11px] font-bold text-gray-400 uppercase tracking-wider">Cập nhật lần cuối</th>
                        <th class="px-6 py-4 text-[11px] font-bold text-gray-400 uppercase tracking-wider text-right">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var med in pagedResult.Items)
                    {
                        string sku = $"PH-{(med.CategoryName.Length >= 2 ? med.CategoryName.Substring(0, 2).ToUpper() : "MD")}-{med.MedicineId.ToString("D3")}";

                        <tr class="hover:bg-gray-50/80 transition-colors">
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-lg text-[#00685f] bg-[#00685f]/10 border border-[#00685f]/20 flex items-center justify-center shadow-sm">
                                        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">pill</span>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-800">@med.MedicineName</p>
                                        <p class="text-[11px] text-gray-500 font-mono mt-0.5 tracking-wide">SKU: @sku</p>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm text-gray-600">@med.CategoryName</span>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-sm text-gray-600">@(string.IsNullOrEmpty(med.Manufacturer) ? "Đang cập nhật" : med.Manufacturer)</span>
                            </td>
                            @* ĐÃ SỬA: Hiển thị thời gian thực từ thuộc tính cơ sở dữ liệu *@
                            <td class="px-6 py-4">
                                <p class="text-xs text-gray-800 font-medium">@med.UpdatedAt.ToString("HH:mm"),</p>
                                <p class="text-xs text-gray-500 mt-0.5">@med.UpdatedAt.ToString("dd/MM/yyyy")</p>
                                <p class="text-[10px] text-gray-400 mt-0.5 italic">Bởi @(string.IsNullOrEmpty(med.UpdatedBy) ? "Hệ thống" : med.UpdatedBy)</p>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center justify-end gap-1">
                                    <a href="/medications/edit/@med.MedicineId" class="text-gray-400 hover:text-blue-600 hover:bg-blue-50 p-1.5 rounded transition-colors" title="Sửa">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </a>
                                    <button @onclick="() => DeleteMedicine(med.MedicineId, med.MedicineName)" class="text-gray-400 hover:text-red-600 hover:bg-red-50 p-1.5 rounded transition-colors" title="Xóa">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* --- FOOTER PHÂN TRANG --- *@
        <div class="px-6 py-4 border-t border-gray-100 bg-gray-50/30 flex items-center justify-between">
            @{
                int startItem = (pagedResult.CurrentPage - 1) * pagedResult.PageSize + 1;
                int endItem = Math.Min(pagedResult.CurrentPage * pagedResult.PageSize, pagedResult.TotalItems);
            }
            <span class="text-xs text-gray-500 font-medium">
                Hiển thị @startItem - @endItem trên @pagedResult.TotalItems thuốc
            </span>

            <div class="flex items-center gap-1">
                <button disabled="@(currentPage == 1)" @onclick="() => LoadData(currentPage - 1)" class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-500 hover:bg-white disabled:opacity-50 transition-colors bg-white shadow-sm">
                    <span class="material-symbols-outlined text-[18px]">chevron_left</span>
                </button>

                @for (int i = 1; i <= pagedResult.TotalPages; i++)
                {
                    var pageNumber = i;
                    <button class="w-8 h-8 flex items-center justify-center rounded text-sm font-medium transition-colors @(currentPage == pageNumber ? "bg-[#00685f] text-white shadow-sm" : "border border-gray-200 text-gray-600 bg-white hover:bg-gray-50")"
                            @onclick="() => LoadData(pageNumber)">
                        @pageNumber
                    </button>
                }

                <button disabled="@(currentPage == pagedResult.TotalPages)" @onclick="() => LoadData(currentPage + 1)" class="w-8 h-8 flex items-center justify-center rounded border border-gray-200 text-gray-500 hover:bg-white disabled:opacity-50 transition-colors bg-white shadow-sm">
                    <span class="material-symbols-outlined text-[18px]">chevron_right</span>
                </button>
            </div>
        </div>
    }
</div>

@code {
    // THUỘC TÍNH THUỐC (Đã bổ sung trường thời gian thực)
    public class MedicineDto
    {
        public int MedicineId { get; set; }
        public string MedicineName { get; set; } = "";
        public string CategoryName { get; set; } = "";
        public string DosageForm { get; set; } = "";
        public string Manufacturer { get; set; } = "";
        public DateTime UpdatedAt { get; set; } = DateTime.Now; // Trường thời gian thực
        public string UpdatedBy { get; set; } = "Admin";
    }

    // Class nhận danh mục để đổ vào Dropdown bộ lọc
    public class CategoryDropdownDto
    {
        public int CategoryId { get; set; }
        public string CategoryName { get; set; } = "";
    }

    public class PagedResult<T> { public List<T> Items { get; set; } = new(); public int TotalItems { get; set; } public int CurrentPage { get; set; } public int PageSize { get; set; } public int TotalPages { get; set; } }

    private PagedResult<MedicineDto>? pagedResult;
    private List<CategoryDropdownDto> categoriesList = new(); // Danh sách chứa các danh mục thuốc

    [SupplyParameterFromQuery(Name = "search")]
    public string? SearchKeyword { get; set; }

    // Biến lưu trữ ID danh mục đang được chọn để lọc
    public string SelectedCategoryId { get; set; } = "";

    private string? errorMessage;
    private bool isLoading = true;
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (string.IsNullOrEmpty(token)) { NavigationManager.NavigateTo("/login"); return; }

            Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);

            // Tải danh mục trước để chuẩn bị cho bộ lọc, sau đó tải danh sách thuốc
            await LoadCategories();
            await LoadData(currentPage);
            StateHasChanged();
        }
    }

    // Hàm gọi API lấy toàn bộ danh mục đổ vào ô Select
    private async Task LoadCategories()
    {
        try
        {
            // Tận dụng API phân trang danh mục có sẵn của bạn, lấy kích thước lớn để hiển thị đủ danh mục
            var res = await Http.GetFromJsonAsync<PagedResult<CategoryDropdownDto>>("api/MedicineCategory?page=1&pageSize=100");
            if (res != null) categoriesList = res.Items;
        }
        catch { /* Bỏ qua để tránh treo giao diện */ }
    }

    private async Task LoadData(int page)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            string apiUrl = $"api/Medicine?page={page}&pageSize={pageSize}";

            // Nối chuỗi tìm kiếm từ thanh Navbar (nếu có)
            if (!string.IsNullOrWhiteSpace(SearchKeyword))
                apiUrl += $"&search={Uri.EscapeDataString(SearchKeyword.Trim())}";

            // NẾU CÓ CHỌN DANH MỤC LỌC -> NỐI THÊM THAM SỐ VÀO API
            if (!string.IsNullOrEmpty(SelectedCategoryId))
                apiUrl += $"&categoryId={SelectedCategoryId}";

            pagedResult = await Http.GetFromJsonAsync<PagedResult<MedicineDto>>(apiUrl);

            if (pagedResult != null) currentPage = pagedResult.CurrentPage;
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized) { NavigationManager.NavigateTo("/login"); }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound) { pagedResult = new PagedResult<MedicineDto>(); }
        catch (Exception ex) { errorMessage = $"Kết nối API thất bại. Chi tiết: {ex.Message}"; }
        finally { isLoading = false; StateHasChanged(); }
    }

    // Sự kiện xảy ra khi người dùng thay đổi lựa chọn trên Dropdown danh mục
    private async Task OnCategoryFilterChanged()
    {
        currentPage = 1; // Đưa về trang đầu tiên khi đổi bộ lọc
        await LoadData(currentPage);
    }

    private async Task DeleteMedicine(int id, string name)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc chắn muốn xóa thuốc '{name}' khỏi kho không?");
        if (confirmed)
        {
            isLoading = true;
            StateHasChanged();
            try
            {
                var response = await Http.DeleteAsync($"api/Medicine/{id}");
                if (response.IsSuccessStatusCode) await LoadData(currentPage);
                else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized) NavigationManager.NavigateTo("/login");
                else errorMessage = $"Không thể xóa. Máy chủ từ chối: {response.StatusCode}";
            }
            catch (Exception ex) { errorMessage = $"Lỗi kết nối mạng: {ex.Message}"; }
            finally { isLoading = false; StateHasChanged(); }
        }
    }
}