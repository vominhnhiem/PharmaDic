@page "/medications"
@using PharmaDicBackEnd.ApiService.DTOs
@inject HttpClient Http
@rendermode InteractiveServer


@* --- HEADER --- *@
<div class="flex justify-between items-center mb-6">
    <div>
        <h2 class="text-2xl font-bold text-primary">Quản lý thuốc</h2>
        <p class="text-on-surface-variant text-sm mt-1">Danh sách tất cả các loại thuốc trong hệ thống</p>
    </div>
    <button class="bg-primary text-white px-4 py-2 rounded-md flex items-center gap-2 hover:bg-primary/90 transition-shadow shadow-sm">
        <span class="material-symbols-outlined text-sm" style="font-variation-settings: 'wght' 600;">add</span>
        Thêm thuốc mới
    </button>
</div>

@* --- BẢNG DỮ LIỆU --- *@
<div class="bg-white rounded-xl shadow-sm border border-border overflow-hidden">
    @if (isLoading)
    {
        <div class="p-12 text-center text-primary flex flex-col items-center justify-center">
            <span class="material-symbols-outlined animate-spin text-4xl mb-3">progress_activity</span>
            <p class="font-medium text-on-surface-variant">Đang tải dữ liệu từ hệ thống...</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-12 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error-container text-error mb-4">
                <span class="material-symbols-outlined text-3xl">error</span>
            </div>
            <h3 class="text-lg font-bold text-error mb-2">Đã xảy ra lỗi</h3>
            <p class="text-on-surface-variant max-w-md mx-auto">@errorMessage</p>
            <button @onclick="() => LoadData(currentPage)" class="mt-4 px-4 py-2 border border-error text-error rounded-md hover:bg-error-container transition-colors">
                Thử lại
            </button>
        </div>
    }
    else if (pagedResult == null || !pagedResult.Items.Any())
    {
        <div class="p-16 text-center">
            <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-surface-container text-on-surface-variant mb-4">
                <span class="material-symbols-outlined text-4xl">medication</span>
            </div>
            <h3 class="text-xl font-bold text-on-surface mb-2">Chưa có dữ liệu thuốc</h3>
            <p class="text-on-surface-variant max-w-sm mx-auto mb-6">Hệ thống của bạn hiện chưa có loại thuốc nào được đăng ký.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm whitespace-nowrap">
                <thead class="bg-surface-container-lowest border-b border-border text-on-surface-variant">
                    <tr>
                        <th class="px-6 py-4 font-semibold w-16">ID</th>
                        <th class="px-6 py-4 font-semibold">Tên thuốc</th>
                        <th class="px-6 py-4 font-semibold">Danh mục</th>
                        <th class="px-6 py-4 font-semibold">Dạng bào chế</th>
                        <th class="px-6 py-4 font-semibold">Nhà sản xuất</th>
                        <th class="px-6 py-4 font-semibold text-right w-24">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-border">
                    @foreach (var med in pagedResult.Items)
                    {
                        <tr class="hover:bg-surface-container-lowest/60 transition-colors">
                            <td class="px-6 py-4 font-medium text-on-surface-variant">#@med.MedicineId</td>
                            <td class="px-6 py-4 font-bold text-primary">@med.MedicineName</td>
                            <td class="px-6 py-4">
                                <span class="px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-xs font-medium">
                                    @med.CategoryName
                                </span>
                            </td>
                            <td class="px-6 py-4 text-on-surface-variant">@med.DosageForm</td>
                            <td class="px-6 py-4 text-on-surface-variant">@med.Manufacturer</td>
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <button class="text-primary hover:bg-primary/10 w-8 h-8 rounded-full flex items-center justify-center transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">edit</span>
                                    </button>
                                    <button class="text-error hover:bg-error/10 w-8 h-8 rounded-full flex items-center justify-center transition-colors">
                                        <span class="material-symbols-outlined text-[20px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* --- FOOTER PHÂN TRANG --- *@
        <div class="px-6 py-4 border-t border-border bg-surface-container-lowest flex items-center justify-between">
            <span class="text-sm text-on-surface-variant">
                Hiển thị <strong>@pagedResult.Items.Count</strong> trên tổng số <strong>@pagedResult.TotalItems</strong> kết quả
            </span>

            <div class="flex items-center gap-2">
                @* Nút Lùi *@
                <button class="px-3 py-1 border border-border rounded-md hover:bg-surface-container disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        disabled="@(currentPage == 1)"
                        @onclick="() => LoadData(currentPage - 1)">
                    Trước
                </button>

                @* Các số trang *@
                @for (int i = 1; i <= pagedResult.TotalPages; i++)
                {
                    var pageNumber = i; // Bắt buộc phải gán biến cục bộ trong vòng lặp Blazor
                                        <button class="px-3 py-1 border rounded-md transition-colors @(currentPage == pageNumber ? "bg-primary text-white border-primary" : "border-border hover:bg-surface-container")"
                                                @onclick="() => LoadData(pageNumber)">
                                            @pageNumber
                                        </button>
                }

                @* Nút Tiến *@
                <button class="px-3 py-1 border border-border rounded-md hover:bg-surface-container disabled:opacity-50 disabled:cursor-not-allowed transition-colors"
                        disabled="@(currentPage == pagedResult.TotalPages)"
                        @onclick="() => LoadData(currentPage + 1)">
                    Sau
                </button>
            </div>
        </div>
    }
</div>

@code {
    // Đổi từ List sang PagedResult
    private PagedResult<MedicineDto>? pagedResult;

    private string? errorMessage;
    private bool isLoading = true;

    // Tham số phân trang mặc định
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        await LoadData(currentPage);
    }

    private async Task LoadData(int page)
    {
        isLoading = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            // Truyền tham số page và pageSize lên API
            pagedResult = await Http.GetFromJsonAsync<PagedResult<MedicineDto>>($"api/Medicine?page={page}&pageSize={pageSize}");

            // Cập nhật lại trang hiện tại sau khi gọi API thành công
            if (pagedResult != null)
            {
                currentPage = pagedResult.CurrentPage;
            }
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            // Xử lý riêng biệt khi database không có dữ liệu
            pagedResult = new PagedResult<MedicineDto>();
        }
        catch (Exception ex)
        {
            errorMessage = $"Kết nối API thất bại. Chi tiết: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}