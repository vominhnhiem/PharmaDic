@page "/medications"

@* --- TIÊU ĐỀ TRANG VÀ NÚT THÊM --- *@
<div class="flex justify-between items-end mb-8">
    <div>
        <h2 class="text-3xl font-bold text-on-background">Danh mục thuốc</h2>
        <p class="text-sm text-on-surface-variant mt-1">Quản lý và cập nhật thông tin kho dược phẩm hệ thống.</p>
    </div>
    <button class="flex items-center gap-2 bg-primary text-white px-6 py-2.5 rounded-lg font-semibold hover:bg-[#005049] transition-all active:scale-95 shadow-sm">
        <span class="material-symbols-outlined">add</span>
        Thêm thuốc mới
    </button>
</div>

@* --- KHỐI THỐNG KÊ (STATS CARDS) --- *@
<div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
    <div class="bg-surface p-6 rounded-xl border border-border medical-shadow">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest">Tổng thuốc</p>
        <h3 class="text-3xl font-bold mt-2 text-on-background">1,284</h3>
        <div class="mt-2 flex items-center gap-1 text-success text-xs font-medium">
            <span class="material-symbols-outlined text-[16px]">trending_up</span>
            <span>+12 tháng này</span>
        </div>
    </div>
    <div class="bg-surface p-6 rounded-xl border border-border medical-shadow">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest">Sắp hết hàng</p>
        <h3 class="text-3xl font-bold mt-2 text-orange-500">24</h3>
        <div class="mt-2 flex items-center gap-1 text-on-surface-variant text-xs">
            <span>Cần nhập thêm ngay</span>
        </div>
    </div>
    <div class="bg-surface p-6 rounded-xl border border-border medical-shadow">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest">Hết hạn (30 ngày)</p>
        <h3 class="text-3xl font-bold mt-2 text-red-600">8</h3>
        <div class="mt-2 flex items-center gap-1 text-on-surface-variant text-xs">
            <span>Trong kho lưu trữ</span>
        </div>
    </div>
    <div class="bg-surface p-6 rounded-xl border border-border medical-shadow">
        <p class="text-xs font-semibold text-on-surface-variant uppercase tracking-widest">Nhà cung cấp</p>
        <h3 class="text-3xl font-bold mt-2 text-tertiary">42</h3>
        <div class="mt-2 flex items-center gap-1 text-on-surface-variant text-xs">
            <span>Đối tác đã xác thực</span>
        </div>
    </div>
</div>

@* --- THANH ĐIỀU KHIỂN BỘ LỌC (CONTROL BAR) --- *@
<div class="bg-surface p-4 rounded-t-xl border border-border border-b-0 flex flex-wrap items-center justify-between gap-4">
    <div class="flex items-center gap-3">
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">filter_list</span>
            <select class="pl-10 pr-8 py-2 bg-gray-50 border border-border rounded-lg text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary appearance-none">
                <option>Tất cả danh mục</option>
                <option>Kháng sinh</option>
                <option>Giảm đau</option>
                <option>Vitamin & Thực phẩm chức năng</option>
                <option>Tim mạch</option>
            </select>
        </div>
        <div class="relative">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">sort</span>
            <select class="pl-10 pr-8 py-2 bg-gray-50 border border-border rounded-lg text-sm focus:ring-2 focus:ring-primary/20 focus:border-primary appearance-none">
                <option>Mới nhất</option>
                <option>Tên A-Z</option>
                <option>Số lượng giảm dần</option>
            </select>
        </div>
    </div>
    <div class="flex items-center gap-2">
        <button class="p-2 border border-border rounded-lg hover:bg-gray-100 transition-colors" title="Tải xuống">
            <span class="material-symbols-outlined text-on-surface-variant">download</span>
        </button>
        <button class="p-2 border border-border rounded-lg hover:bg-gray-100 transition-colors" title="In dữ liệu">
            <span class="material-symbols-outlined text-on-surface-variant">print</span>
        </button>
    </div>
</div>

@* --- BẢNG DỮ LIỆU CHÍNH (DATA TABLE) --- *@
<div class="bg-surface rounded-b-xl border border-border medical-shadow overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead class="bg-gray-50 border-b border-border">
            <tr>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Tên thuốc</th>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Danh mục</th>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Nhà sản xuất</th>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-center">Trạng thái kho</th>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Cập nhật lần cuối</th>
                <th class="px-6 py-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">Thao tác</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-border">
            @foreach (var drug in Drugs)
            {
                <tr class="hover:bg-gray-50/50 transition-all duration-200 hover:translate-x-1 group">
                    <td class="px-6 py-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded flex items-center justify-center @drug.IconBgClass @drug.IconTextClass">
                                <span class="material-symbols-outlined">@drug.IconName</span>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-on-background">@drug.Name</p>
                                <p class="text-xs text-on-surface-variant">SKU: @drug.Sku</p>
                            </div>
                        </div>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-on-surface-variant">@drug.Category</span>
                    </td>
                    <td class="px-6 py-4">
                        <span class="text-sm text-on-surface-variant">@drug.Manufacturer</span>
                    </td>
                    <td class="px-6 py-4 text-center">
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-[11px] font-bold uppercase @drug.StatusBgClass @drug.StatusTextClass">
                            @drug.StatusText
                        </span>
                    </td>
                    <td class="px-6 py-4">
                        <p class="text-sm text-on-surface-variant">@drug.LastUpdated</p>
                        <p class="text-xs text-gray-400">Bởi @drug.UpdatedBy</p>
                    </td>
                    <td class="px-6 py-4 text-right">
                        <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-150">
                            <button class="p-1.5 text-primary hover:bg-primary/10 rounded transition-colors" title="Sửa">
                                <span class="material-symbols-outlined text-[20px]">edit</span>
                            </button>
                            <button class="p-1.5 text-red-600 hover:bg-red-50 rounded transition-colors" title="Xóa">
                                <span class="material-symbols-outlined text-[20px]">delete</span>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @* --- PHÂN TRANG (PAGINATION) --- *@
    <div class="bg-gray-50 px-6 py-4 flex items-center justify-between border-t border-border">
        <p class="text-xs text-on-surface-variant">Hiển thị 1 - 4 trên 1,284 thuốc</p>
        <div class="flex items-center gap-1">
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border text-on-surface-variant hover:bg-white transition-colors disabled:opacity-50" disabled>
                <span class="material-symbols-outlined text-[18px]">chevron_left</span>
            </button>
            <button class="w-8 h-8 flex items-center justify-center rounded bg-primary text-white text-xs font-semibold">1</button>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border text-on-surface-variant hover:bg-white transition-colors text-xs">2</button>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border text-on-surface-variant hover:bg-white transition-colors text-xs">3</button>
            <span class="px-2 text-on-surface-variant text-xs">...</span>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border text-on-surface-variant hover:bg-white transition-colors text-xs">321</button>
            <button class="w-8 h-8 flex items-center justify-center rounded border border-border text-on-surface-variant hover:bg-white transition-colors">
                <span class="material-symbols-outlined text-[18px]">chevron_right</span>
            </button>
        </div>
    </div>
</div>

@* --- NÚT AI TRỢ GIÚP (STICKY AI FLOATING BUTTON) --- *@
<div class="fixed bottom-8 right-8 group z-50">
    <div class="absolute -top-12 right-0 bg-gray-900 text-white text-xs px-3 py-1.5 rounded-lg shadow-md opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap pointer-events-none">
        Hỗ trợ phân tích tồn kho AI
    </div>
    <button class="w-14 h-14 bg-primary text-white rounded-full shadow-lg flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
        <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
    </button>
</div>

@code {
    // Khai báo cấu trúc dữ liệu mẫu cho danh sách thuốc
    private List<DrugModel> Drugs = new()
    {
        new DrugModel {
            Name = "Amoxicillin 500mg", Sku = "PH-AM-001", Category = "Kháng sinh", Manufacturer = "DHG Pharma",
            StatusText = "Còn hàng (450)", LastUpdated = "14:20, 24/05/2024", UpdatedBy = "Admin", IconName = "pill",
            IconBgClass = "bg-teal-50", IconTextClass = "text-primary", StatusBgClass = "bg-emerald-50", StatusTextClass = "text-success"
        },
        new DrugModel {
            Name = "Paracetamol Extra", Sku = "PH-PA-052", Category = "Giảm đau", Manufacturer = "Sanofi Aventis",
            StatusText = "Sắp hết (12)", LastUpdated = "09:15, 23/05/2024", UpdatedBy = "Hệ thống", IconName = "vaccines",
            IconBgClass = "bg-blue-50", IconTextClass = "text-tertiary", StatusBgClass = "bg-amber-50", StatusTextClass = "text-orange-500"
