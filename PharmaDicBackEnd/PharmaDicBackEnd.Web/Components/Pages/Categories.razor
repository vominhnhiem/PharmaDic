@page "/categories"
@rendermode InteractiveServer
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Quản lý Danh mục - PharmaCheck</PageTitle>

<div class="mb-6 flex justify-between items-end">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-primary">Danh mục Thuốc</h2>
        <p class="text-on-surface-variant mt-1">Quản lý các nhóm và phân loại thuốc trong hệ thống</p>
    </div>
    <button class="flex items-center gap-2 px-4 py-2 bg-primary text-white font-label-md rounded hover:shadow-lg transition-all" @onclick="OpenCreateModal">
        <span class="material-symbols-outlined text-[18px]">add</span>
        Thêm danh mục mới
    </button>
</div>

<div class="bg-surface border border-border rounded-lg shadow-sm overflow-hidden">
    @if (isLoading)
    {
        <div class="flex justify-center items-center py-16">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-primary"></div>
            <span class="ml-4 text-on-surface-variant font-medium">Đang thao tác dữ liệu...</span>
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="p-8 text-error text-center bg-error/5">
            <span class="material-symbols-outlined text-[48px] mb-3 opacity-80">error_outline</span>
            <h3 class="font-bold text-lg mb-1">Cảnh báo hệ thống</h3>
            <p>@errorMessage</p>
            <button class="mt-4 px-4 py-2 bg-error text-white rounded font-label-md" @onclick="LoadCategoriesData">Tải lại trang</button>
        </div>
    }
    else if (categories != null && categories.Any())
    {
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-surface-container-low border-b border-border text-on-surface-variant font-label-md">
                        <th class="p-4 font-semibold w-20 text-center">ID</th>
                        <th class="p-4 font-semibold w-1/3">Tên Danh mục</th>
                        <th class="p-4 font-semibold">Mô tả chi tiết</th>
                        <th class="p-4 font-semibold w-32 text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody class="text-body-md text-on-surface">
                    @foreach (var cat in categories)
                    {
                        <tr class="border-b border-border hover:bg-surface-container-lowest transition-colors">
                            @* SỬA LỖI Ở ĐÂY: Dùng CategoryId và CategoryName *@
                            <td class="p-4 text-center font-bold text-on-surface-variant">#@cat.CategoryId</td>
                            <td class="p-4 font-bold text-primary">@cat.CategoryName</td>
                            <td class="p-4 text-on-surface-variant truncate max-w-md" title="@cat.Description">
                                @(string.IsNullOrWhiteSpace(cat.Description) ? "— Không có mô tả —" : cat.Description)
                            </td>
                            <td class="p-4 text-center">
                                <div class="flex justify-center gap-2">
                                    <button class="p-1.5 bg-warning/10 text-warning rounded hover:bg-warning/20 transition-colors" title="Chỉnh sửa" @onclick="() => OpenEditModal(cat)">
                                        <span class="material-symbols-outlined text-[18px]">edit</span>
                                    </button>
                                    <button class="p-1.5 bg-error/10 text-error rounded hover:bg-error/20 transition-colors" title="Xóa" @onclick="() => DeleteCategory(cat.CategoryId)">
                                        <span class="material-symbols-outlined text-[18px]">delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="p-16 text-center text-on-surface-variant">
            <span class="material-symbols-outlined text-[64px] mb-4 opacity-40">category</span>
            <h3 class="font-bold text-xl mb-2 text-on-surface">Chưa có dữ liệu</h3>
            <p class="font-body-md">Hiện tại chưa có danh mục thuốc nào được lưu trữ trong hệ thống.</p>
        </div>
    }
</div>

@if (isModalOpen)
{
    <div class="fixed inset-0 bg-black/50 z-50 flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-surface rounded-lg shadow-xl w-full max-w-md overflow-hidden transform transition-all">
            <div class="px-6 py-4 border-b border-border flex justify-between items-center bg-surface-container-low">
                <h3 class="font-title-lg text-primary fw-bold">@(isEditMode ? "Sửa Danh mục" : "Thêm Danh mục mới")</h3>
                <button class="text-on-surface-variant hover:text-error transition-colors" @onclick="CloseModal">
                    <span class="material-symbols-outlined">close</span>
                </button>
            </div>

            <div class="p-6 space-y-4">
                <div>
                    <label class="block font-label-md text-on-surface mb-1">Tên danh mục <span class="text-error">*</span></label>
                    @* SỬA LỖI BINDING LÊN FORM Ở ĐÂY *@
                    <input type="text" class="w-full px-3 py-2 border border-border rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-surface"
                           @bind="currentCategory.CategoryName" placeholder="VD: Kháng sinh..." />
                </div>
                <div>
                    <label class="block font-label-md text-on-surface mb-1">Mô tả</label>
                    <textarea class="w-full px-3 py-2 border border-border rounded focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary bg-surface"
                              rows="3" @bind="currentCategory.Description" placeholder="Mô tả chi tiết nhóm thuốc..."></textarea>
                </div>
            </div>

            <div class="px-6 py-4 border-t border-border bg-surface-container-lowest flex justify-end gap-3">
                <button class="px-4 py-2 border border-border rounded font-label-md text-on-surface hover:bg-surface-container-low transition-colors" @onclick="CloseModal">
                    Hủy bỏ
                </button>
                <button class="px-4 py-2 bg-primary text-white rounded font-label-md hover:shadow-md transition-all flex items-center gap-2" @onclick="SaveCategory" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <div class="animate-spin rounded-full h-4 w-4 border-b-2 border-white"></div>
                        <span>Đang lưu...</span>
                    }
                    else
                    {
                        <span class="material-symbols-outlined text-[18px]">save</span>
                        <span>Lưu dữ liệu</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    // VÁ LỖI CỐT LÕI: Đổi lại Id thành CategoryId, Name thành CategoryName
    public class CategoryDto
    {
        public int CategoryId { get; set; }
        public string CategoryName { get; set; } = "";
        public string? Description { get; set; }
    }

    private List<CategoryDto>? categories;
    private bool isLoading = true;
    private string errorMessage = "";

    private bool isModalOpen = false;
    private bool isEditMode = false;
    private bool isProcessing = false;

    private CategoryDto currentCategory = new CategoryDto();

    protected override async Task OnInitializedAsync()
    {
        await LoadCategoriesData();
    }

    private async Task LoadCategoriesData()
    {
        isLoading = true;
        errorMessage = "";
        try
        {
            categories = await Http.GetFromJsonAsync<List<CategoryDto>>("api/MedicineCategory");
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể lấy dữ liệu: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        isEditMode = false;
        currentCategory = new CategoryDto();
        isModalOpen = true;
    }

    private void OpenEditModal(CategoryDto cat)
    {
        isEditMode = true;
        // Bẫy tham chiếu: Map đúng tên biến mới
        currentCategory = new CategoryDto
        {
            CategoryId = cat.CategoryId,
            CategoryName = cat.CategoryName,
            Description = cat.Description
        };
        isModalOpen = true;
    }

    private void CloseModal()
    {
        isModalOpen = false;
        errorMessage = "";
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(currentCategory.CategoryName))
        {
            await JS.InvokeVoidAsync("alert", "Tên danh mục không được để trống!");
            return;
        }

        isProcessing = true;
        try
        {
            HttpResponseMessage response;

            if (isEditMode)
            {
                // Gửi kèm CategoryId lên URL để API biết đang sửa dòng nào
                response = await Http.PutAsJsonAsync($"api/MedicineCategory/{currentCategory.CategoryId}", currentCategory);
            }
            else
            {
                // Gọi API thêm mới
                response = await Http.PostAsJsonAsync("api/MedicineCategory", currentCategory);
            }

            if (response.IsSuccessStatusCode)
            {
                CloseModal();
                await LoadCategoriesData();
            }
            else
            {
                await JS.InvokeVoidAsync("alert", $"Lỗi từ Server: {response.StatusCode}. Hãy đảm bảo API Post/Put của bạn hoạt động.");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Lỗi mạng: {ex.Message}");
        }
        finally
        {
            isProcessing = false;
        }
    }

    private async Task DeleteCategory(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>("confirm", "CẢNH BÁO: Bạn có chắc chắn muốn xóa danh mục này? Hành động này không thể hoàn tác!");
        if (!confirmed) return;

        isLoading = true;
        try
        {
            var response = await Http.DeleteAsync($"api/MedicineCategory/{id}");

            if (response.IsSuccessStatusCode)
            {
                await LoadCategoriesData();
            }
            else
            {
                errorMessage = $"Hệ thống từ chối xóa (Mã lỗi: {response.StatusCode}). Có thể danh mục này đang chứa thuốc bên trong.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi xóa: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}