@page "/users"

<div class="p-6 bg-gray-50 min-h-screen">
    <!-- Header -->
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-gray-900">Quản lý người dùng</h1>
        <p class="text-gray-600">Phê duyệt và quản lý danh sách dược sĩ đăng ký hệ thống PharmaCheck.</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-4 gap-4 mb-6">
        <StatCard Title="Tổng dược sĩ" Value="1,284" Change="+12%" />
        <StatCard Title="Chờ xác minh" Value="28" IsAlert="true" />
        <StatCard Title="Hoạt động hôm nay" Value="452" />
        <StatCard Title="Độ chính xác AI" Value="99.2%" />
    </div>

    <!-- Main Table Section -->
    <div class="bg-white rounded-lg shadow p-6">
        <div class="flex justify-between mb-4">
            <div class="flex gap-4">
                <button class="text-teal-700 font-semibold border-b-2 border-teal-700">Tất cả</button>
                <button class="text-gray-500">Đã xác minh</button>
                <button class="text-gray-500">Chờ duyệt</button>
            </div>
            <div class="flex gap-2">
                <button class="px-4 py-2 border rounded text-sm">Lọc dữ liệu</button>

            </div>
        </div>

        <table class="w-full text-left">
            <thead class="text-gray-400 text-xs uppercase border-b">
                <tr>
                    <th class="py-3">Họ tên & Email</th>
                    <th class="py-3">Bệnh viện / Phòng khám</th>
                    <th class="py-3">Ngày đăng ký</th>
                    <th class="py-3">Trạng thái</th>
                    <th class="py-3">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                <!-- Dòng dữ liệu mẫu -->
                <tr class="border-b">
                    <td class="py-4 flex items-center gap-3">
                        <div class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center font-bold text-blue-700">NM</div>
                        <div>
                            <div class="font-bold">Nguyễn Minh Anh</div>
                            <div class="text-xs text-gray-500">minhanh.nguyen@clinic.vn</div>
                        </div>
                    </td>
                    <td class="py-4">Bệnh viện Bạch Mai</td>
                    <td class="py-4 text-sm text-gray-600">12/10/2023 09:45</td>
                    <td class="py-4"><span class="px-2 py-1 bg-yellow-50 text-yellow-600 text-xs rounded">Chờ duyệt</span></td>
                    <td class="py-4"><button class="bg-teal-900 text-white px-4 py-1 rounded text-sm">Xác minh</button></td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

@code {
    // Component con cho các ô thông số
    public class StatCard : ComponentBase
    {
        [Parameter] public string Title { get; set; }
        [Parameter] public string Value { get; set; }
        [Parameter] public string Change { get; set; }
        [Parameter] public bool IsAlert { get; set; }
    }
}