@page "/medications/add"
@using PharmaDicBackEnd.ApiService.DTOs
@using System.Net.Http.Headers
@inject HttpClient Http
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

@* --- HEADER & NÚT QUAY LẠI --- *@
<div class="mb-6">
    <button @onclick="GoBack" class="text-primary hover:underline flex items-center gap-1 mb-2 text-sm font-medium transition-colors">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Quay lại danh sách
    </button>
    <h2 class="text-2xl font-bold text-primary">Thêm Thuốc Mới</h2>
    <p class="text-on-surface-variant text-sm mt-1">Điền đầy đủ các thông tin bắt buộc (*) để đăng ký thuốc vào hệ thống.</p>
</div>

@* --- FORM NHẬP LIỆU --- *@
<div class="bg-white rounded-xl shadow-sm border border-border p-8 max-w-3xl">
    <EditForm Model="newMedicine" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
            <div class="col-span-2">
                <label class="block text-sm font-semibold text-on-surface mb-1">Tên thuốc *</label>
                <InputText @bind-Value="newMedicine.MedicineName" class="w-full px-4 py-2 bg-surface-container-lowest border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="VD: Paracetamol 500mg" />
                <ValidationMessage For="@(() => newMedicine.MedicineName)" class="text-error text-xs mt-1 font-medium" />
            </div>

            @* Đã thay đổi thành Dropdown chọn tên danh mục *@
            <div>
                <label class="block text-sm font-semibold text-on-surface mb-1">Danh mục thuốc *</label>
                <InputSelect @bind-Value="newMedicine.CategoryId" class="w-full px-4 py-2 bg-surface-container-lowest border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
                    <option value="0">-- Chọn danh mục --</option>
                    @if (categories != null)
                    {
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryId.ToString()">@cat.CategoryName</option>
                        }
                    }
                </InputSelect>
                <ValidationMessage For="@(() => newMedicine.CategoryId)" class="text-error text-xs mt-1 font-medium" />
            </div>

            <div>
                <label class="block text-sm font-semibold text-on-surface mb-1">Dạng bào chế</label>
                <InputText @bind-Value="newMedicine.DosageForm" class="w-full px-4 py-2 bg-surface-container-lowest border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="VD: Viên nén, Siro..." />
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-on-surface mb-1">Nhà sản xuất</label>
                <InputText @bind-Value="newMedicine.Manufacturer" class="w-full px-4 py-2 bg-surface-container-lowest border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="VD: Dược Hậu Giang" />
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-on-surface mb-1">Công dụng chính</label>
                <InputTextArea @bind-Value="newMedicine.Uses" rows="3" class="w-full px-4 py-2 bg-surface-container-lowest border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" placeholder="Mô tả công dụng của thuốc..." />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(submitError))
        {
            <div class="bg-error-container text-error px-4 py-3 rounded-md text-sm mb-6 flex items-center gap-2">
                <span class="material-symbols-outlined text-lg">warning</span>
                @submitError
            </div>
        }

        <div class="flex justify-end gap-3 pt-4 border-t border-border">
            <button type="button" @onclick="GoBack" class="px-5 py-2 border border-border text-on-surface-variant font-medium rounded-md hover:bg-surface-container transition-colors">
                Hủy bỏ
            </button>
            <button type="submit" disabled="@isSubmitting" class="px-5 py-2 bg-primary text-white font-medium rounded-md hover:bg-primary/90 disabled:opacity-50 flex items-center gap-2 transition-colors shadow-sm">
                @if (isSubmitting)
                {
                    <span class="material-symbols-outlined animate-spin text-sm">progress_activity</span>
                    <span>Đang lưu...</span>
                }
                else
                {
                    <span class="material-symbols-outlined text-sm">save</span>
                    <span>Lưu thông tin</span>
                }
            </button>
        </div>
    </EditForm>
</div>

@code {
    // Sử dụng đúng class DTO đã được định nghĩa trong dự án
    private CreateMedicineDto newMedicine = new CreateMedicineDto();

    // Khai báo biến chứa danh sách danh mục cho Dropdown
    private List<MedicineCategoryInputDto> categories = new List<MedicineCategoryInputDto>();

    private bool isSubmitting = false;
    private string? submitError;

    // Hàm này chạy ngay khi mở trang để tải danh sách Dropdown
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var catResult = await Http.GetFromJsonAsync<PagedResult<MedicineCategoryInputDto>>("api/MedicineCategory?page=1&pageSize=100");
            if (catResult != null && catResult.Items != null)
            {
                categories = catResult.Items;
            }
        }
        catch (Exception ex)
        {
            submitError = "Không thể tải danh sách danh mục: " + ex.Message;
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        submitError = null;
        StateHasChanged();

        try
        {
            // Bắt buộc đính kèm Token trước khi gọi API POST
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.PostAsJsonAsync("api/Medicine", newMedicine);

            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo("/medications");
            }
            else
            {
                submitError = $"Hệ thống từ chối yêu cầu (Mã lỗi: {response.StatusCode}). Vui lòng kiểm tra lại.";
            }
        }
        catch (Exception ex)
        {
            submitError = $"Mất kết nối tới máy chủ: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void GoBack()
    {
        NavigationManager.NavigateTo("/medications");
    }
}