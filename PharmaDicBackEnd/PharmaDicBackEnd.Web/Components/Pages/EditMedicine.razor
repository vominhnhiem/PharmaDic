@page "/medications/edit/{Id:int}"
@using PharmaDicBackEnd.ApiService.DTOs
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="mb-6">
    <button @onclick="GoBack" class="text-primary hover:underline flex items-center gap-1 mb-2 text-sm font-medium transition-colors">
        <span class="material-symbols-outlined text-sm">arrow_back</span> Quay lại danh sách
    </button>
    <h2 class="text-2xl font-bold text-primary">Cập nhật thông tin Thuốc</h2>
</div>

@if (isLoading)
{
    <p class="text-primary flex items-center gap-2"><span class="material-symbols-outlined animate-spin">progress_activity</span> Đang tải thông tin...</p>
}
else if (updateMedicine != null)
{
    <div class="bg-white rounded-xl shadow-sm border border-border p-8 max-w-3xl">
        <EditForm Model="updateMedicine" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div class="col-span-2">
                    <label class="block text-sm font-semibold mb-1">Tên thuốc *</label>
                    <InputText @bind-Value="updateMedicine.MedicineName" class="w-full px-4 py-2 border rounded-md" />
                    <ValidationMessage For="@(() => updateMedicine.MedicineName)" class="text-error text-xs" />
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-1">Danh mục thuốc *</label>
                    <InputSelect @bind-Value="updateMedicine.CategoryId" class="w-full px-4 py-2 border border-border rounded-md focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all">
                        <option value="0">-- Chọn danh mục --</option>
                        @foreach (var cat in categories)
                        {
                            <option value="@cat.CategoryId">@cat.CategoryName</option>
                        }
                    </InputSelect>
                </div>

                <div>
                    <label class="block text-sm font-semibold mb-1">Dạng bào chế</label>
                    <InputText @bind-Value="updateMedicine.DosageForm" class="w-full px-4 py-2 border rounded-md" />
                </div>

                <div class="col-span-2">
                    <label class="block text-sm font-semibold mb-1">Nhà sản xuất</label>
                    <InputText @bind-Value="updateMedicine.Manufacturer" class="w-full px-4 py-2 border rounded-md" />
                </div>

                <div class="col-span-2">
                    <label class="block text-sm font-semibold mb-1">Công dụng chính</label>
                    <InputTextArea @bind-Value="updateMedicine.Uses" rows="3" class="w-full px-4 py-2 border rounded-md" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(submitError))
            {
                <div class="bg-error-container text-error px-4 py-3 rounded-md text-sm mb-6">@submitError</div>
            }

            <div class="flex justify-end gap-3 pt-4 border-t border-border">
                <button type="button" @onclick="GoBack" class="px-5 py-2 border rounded-md hover:bg-surface-container">Hủy</button>
                <button type="submit" disabled="@isSubmitting" class="px-5 py-2 bg-primary text-white rounded-md hover:bg-primary/90 disabled:opacity-50">Lưu thay đổi</button>
            </div>
        </EditForm>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; } // Nhận ID từ URL

    // Dùng UpdateMedicineDto như trong Controller của bạn
    private UpdateMedicineDto? updateMedicine;
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? submitError;

    private List<MedicineCategoryInputDto> categories = new List<MedicineCategoryInputDto>();
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var catResult = await Http.GetFromJsonAsync<PagedResult<MedicineCategoryInputDto>>("api/MedicineCategory?page=1&pageSize=100");
            if (catResult != null)
            {
                categories = catResult.Items;
            }
            // Gọi API lấy thông tin chi tiết
            var detail = await Http.GetFromJsonAsync<MedicineDetailDto>($"api/Medicine/{Id}");
            if (detail != null)
            {
                // Đẩy dữ liệu vào Form
                updateMedicine = new UpdateMedicineDto
                {
                    MedicineName = detail.MedicineName,
                    // Lưu ý: Nếu DTO của bạn có thiết kế khác, hãy gán (map) cho khớp các trường
                    DosageForm = detail.DosageForm,
                    Manufacturer = detail.Manufacturer,
                    Uses = detail.Uses,
                    Dosage = detail.Dosage,
                    Contraindications = detail.Contraindications,
                    SideEffects = detail.SideEffects
                };
            }
        }
        catch (Exception ex)
        {
            submitError = "Không thể tải dữ liệu thuốc: " + ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        submitError = null;
        StateHasChanged();

        try
        {
            // Gọi lệnh PUT để cập nhật
            var response = await Http.PutAsJsonAsync($"api/Medicine/{Id}", updateMedicine);
            if (response.IsSuccessStatusCode)
            {
                NavigationManager.NavigateTo("/medications");
            }
            else
            {
                submitError = "Cập nhật thất bại. Vui lòng kiểm tra lại.";
            }
        }
        catch (Exception ex)
        {
            submitError = "Lỗi kết nối: " + ex.Message;
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void GoBack() => NavigationManager.NavigateTo("/medications");
}