@* Khai báo định tuyến trang này làm trang chủ mặc định *@
@page "/"
@page "/dashboard"
@inject HttpClient Http

<PageTitle>Tổng quan - PharmaCheck</PageTitle>

<div class="mb-stack-lg flex justify-between items-end">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-primary">Bảng điều khiển tổng quan</h2>
        <p class="font-body-md text-body-md text-on-surface-variant mt-1">Chào mừng trở lại, đây là tóm tắt dữ liệu hệ thống PharmaCheck hôm nay.</p>
    </div>
    <div class="flex gap-3">
        <button class="flex items-center gap-2 px-4 py-2 bg-primary text-white font-label-md rounded hover:shadow-lg transition-all">
            <span class="material-symbols-outlined text-[18px]">refresh</span>
            Làm mới dữ liệu
        </button>
    </div>
</div>

@if (isLoading)
{
    // Bẫy UX: Hiển thị trạng thái đang tải thay vì để trắng trang
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <span class="ml-3 text-lg text-on-surface-variant">Đang đồng bộ dữ liệu từ máy chủ...</span>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    // Bẫy lỗi: Hiển thị lỗi nếu không gọi được API
    <div class="bg-error-container text-error p-4 rounded-lg border border-error mb-6">
        <strong>Lỗi kết nối API: </strong> @errorMessage
    </div>
}
else if (overview != null)
{
    // =========================================================
    // DÒNG MÁU DỮ LIỆU THẬT SẼ CHẢY VÀO 4 THẺ NÀY (Đã điều chỉnh HTML của bạn bạn để chứa 4 thẻ)
    // =========================================================
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-stack-lg">

        @* Thẻ 1: Tổng số thuốc *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-primary/10 rounded">
                    <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">pill</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tổng số thuốc trong từ điển</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalMedicines</h3>
            </div>
        </div>

        @* Thẻ 2: Bệnh lý *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-error/10 rounded">
                    <span class="material-symbols-outlined text-error" style="font-variation-settings: 'FILL' 1;">coronavirus</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Bệnh lý & Triệu chứng</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalDiseases</h3>
            </div>
        </div>

        @* Thẻ 3: Tài khoản người dùng *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-secondary/10 rounded">
                    <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">medical_information</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tài khoản hoạt động</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalUsers</h3>
            </div>
        </div>

        @* Thẻ 4: Danh mục *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-warning/10 rounded">
                    <span class="material-symbols-outlined text-warning" style="font-variation-settings: 'FILL' 1;">category</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Danh mục phân loại</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalCategories</h3>
            </div>
        </div>
    </div>
}

@* (Tạm thời giữ nguyên giao diện Biểu đồ SVG giả của bạn bạn ở đây để không làm vỡ Layout, chúng ta sẽ xử lý biểu đồ thật bằng thư viện JS ở task sau) *@
<div class="grid grid-cols-12 gap-6">
    <div class="col-span-12 bg-surface border border-border rounded-lg p-stack-lg medical-shadow">
        <p class="text-on-surface-variant text-center py-4">Khu vực biểu đồ (Đang chờ tích hợp Chart.js)</p>
    </div>
</div>

@code {
    // Định nghĩa class nội bộ (hoặc tạo file dùng chung) để hứng JSON từ API
    public class DashboardOverviewDto
    {
        public int TotalMedicines { get; set; }
        public int TotalDiseases { get; set; }
        public int TotalUsers { get; set; }
        public int TotalCategories { get; set; }
    }

    private DashboardOverviewDto? overview;
    private bool isLoading = true;
    private string errorMessage = "";

    // Hàm vòng đời: Được gọi tự động khi Blazor load trang này
    protected override async Task OnInitializedAsync()
    {
        await LoadDashboardData();
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        errorMessage = "";
        try
        {
            // Bắn request lên Server API đã cấu hình ở Program.cs
            overview = await Http.GetFromJsonAsync<DashboardOverviewDto>("api/Dashboard/overview");
        }
        catch (HttpRequestException ex)
        {
            errorMessage = "Không thể kết nối đến Máy chủ API. Vui lòng kiểm tra lại Backend.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isLoading = false;
        }
    }
}