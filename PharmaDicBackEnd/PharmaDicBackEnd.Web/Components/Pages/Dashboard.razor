@* Khai báo định tuyến trang này làm trang chủ mặc định *@
@page "/"
@page "/dashboard"
@inject HttpClient Http
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Tổng quan - PharmaCheck</PageTitle>

<div class="mb-stack-lg flex justify-between items-end">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-primary">Bảng điều khiển tổng quan</h2>
        <p class="font-body-md text-body-md text-on-surface-variant mt-1">Chào mừng trở lại, đây là tóm tắt dữ liệu hệ thống PharmaCheck hôm nay.</p>
    </div>
    @* Cặp nút hành động bên phải *@
    <div class="flex gap-3">
        <button class="flex items-center gap-2 px-4 py-2 bg-primary text-white font-label-md rounded hover:shadow-lg transition-all" @onclick="LoadDashboardData">
            <span class="material-symbols-outlined text-[18px]">refresh</span>
            Làm mới dữ liệu
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <span class="ml-3 text-lg text-on-surface-variant">Đang đồng bộ dữ liệu hệ thống...</span>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative mb-6" role="alert">
        <strong class="font-bold">Cảnh báo hệ thống:</strong>
        <span class="block sm:inline"> @errorMessage</span>
        <p class="text-xs mt-1 opacity-75">Gợi ý: Kiểm tra lại Token đăng nhập hoặc phân quyền tại DashboardController.</p>
    </div>
}
else if (overview != null)
{
    @* Mở rộng lưới từ 3 lên 4 cột để hiển thị trọn vẹn 4 nhóm chỉ số thực tế từ Database *@
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-stack-lg">

        @* Thẻ 1: Tổng số thuốc *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-primary/10 rounded">
                    <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">pill</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tổng số thuốc</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalMedicines</h3>
            </div>
        </div>

        @* Thẻ 2: Tổng số bệnh lý *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-red-50 text-red-600 rounded">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">coronavirus</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Bệnh lý & Triệu chứng</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalDiseases</h3>
            </div>
        </div>

        @* Thẻ 3: Người dùng hệ thống *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-secondary/10 rounded">
                    <span class="material-symbols-outlined text-secondary" style="font-variation-settings: 'FILL' 1;">medical_information</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tài khoản người dùng</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalUsers</h3>
            </div>
        </div>

        @* Thẻ 4: Danh mục *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="flex justify-between items-start">
                <div class="p-2 bg-yellow-50 text-yellow-600 rounded">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">category</span>
                </div>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Danh mục phân loại</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalCategories</h3>
            </div>
        </div>
    </div>
}

<div class="grid grid-cols-12 gap-6">
    @* Giữ nguyên khối thiết kế Biểu đồ SVG nguyên bản của bạn bạn *@
    <div class="col-span-12 lg:col-span-8 bg-surface border border-border rounded-lg p-stack-lg medical-shadow hover:-translate-y-0.5 transition-all duration-300">
        <div class="flex justify-between items-center mb-6">
            <div>
                <h4 class="font-title-md text-title-md text-on-surface">Xu hướng tra cứu triệu chứng</h4>
                <p class="text-label-md text-on-surface-variant">Thống kê dữ liệu thực tế theo thời gian thực</p>
            </div>
            <select class="bg-surface-container-low border-border rounded px-3 py-1 text-label-md focus:ring-primary">
                <option>7 ngày qua</option>
                <option>30 ngày qua</option>
                <option>Năm nay</option>
            </select>
        </div>

        <div class="chart-container flex items-end justify-between gap-2 pt-10 relative">
            <svg class="absolute inset-0 w-full h-full p-4 pointer-events-none" viewBox="0 0 800 200">
                <path d="M 0 160 Q 100 140 200 170 T 400 100 T 600 130 T 800 40" fill="none" stroke="#00685f" stroke-linecap="round" stroke-width="3"></path>
                <path d="M 0 160 Q 100 140 200 170 T 400 100 T 600 130 T 800 40 V 200 H 0 Z" fill="url(#gradient-primary)" opacity="0.1"></path>
                <defs>
                    <linearGradient id="gradient-primary" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="#00685f"></stop>
                        <stop offset="100%" stop-color="#ffffff"></stop>
                    </linearGradient>
                </defs>
            </svg>
            <div class="absolute inset-0 flex flex-col justify-between pointer-events-none border-b border-border">
                <div class="w-full border-t border-border/50 border-dashed"></div>
                <div class="w-full border-t border-border/50 border-dashed"></div>
                <div class="w-full border-t border-border/50 border-dashed"></div>
                <div class="w-full border-t border-border/50 border-dashed"></div>
            </div>
            <div class="w-full flex justify-between px-4 mt-2 z-10">
                <span class="text-[10px] text-on-surface-variant">T2</span>
                <span class="text-[10px] text-on-surface-variant">T3</span>
                <span class="text-[10px] text-on-surface-variant">T4</span>
                <span class="text-[10px] text-on-surface-variant">T5</span>
                <span class="text-[10px] text-on-surface-variant">T6</span>
                <span class="text-[10px] text-on-surface-variant">T7</span>
                <span class="text-[10px] text-on-surface-variant">CN</span>
            </div>
        </div>
    </div>

    @* Giữ nguyên khối thiết kế Dòng thời gian hoạt động hệ thống *@
    <div class="col-span-12 lg:col-span-4 bg-surface border border-border rounded-lg p-stack-lg medical-shadow overflow-hidden hover:-translate-y-0.5 transition-all duration-300">
        <div class="flex justify-between items-center mb-6">
            <h4 class="font-title-md text-title-md text-on-surface">Hoạt động gần đây</h4>
            <button class="text-primary text-label-md font-bold hover:underline">Tất cả</button>
        </div>
        <div class="space-y-6">
            <div class="flex gap-4 relative">
                <div class="absolute left-4 top-8 bottom-0 w-px bg-border -mb-6"></div>
                <div class="z-10 w-8 h-8 rounded-full bg-success/20 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-success text-[16px]">add_circle</span>
                </div>
                <div>
                    <p class="text-body-md font-bold">Thuốc mới được thêm</p>
                    <p class="text-body-md text-on-surface-variant">Paracetamol 500mg - Lô hàng #PTC2024</p>
                    <p class="text-label-md text-on-surface-variant/70 mt-1">2 phút trước • Bởi Admin</p>
                </div>
            </div>
            <div class="flex gap-4 relative">
                <div class="z-10 w-8 h-8 rounded-full bg-primary/20 flex items-center justify-center shrink-0">
                    <span class="material-symbols-outlined text-primary text-[16px]">person_add</span>
                </div>
                <div>
                    <p class="text-body-md font-bold">Dược sĩ mới đăng ký</p>
                    <p class="text-body-md text-on-surface-variant">Ds. Nguyễn Văn A - Bệnh viện 108</p>
                    <p class="text-label-md text-on-surface-variant/70 mt-1">45 phút trước • Chờ xác minh</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    public class DashboardOverviewDto
    {
        public int TotalMedicines { get; set; }
        public int TotalDiseases { get; set; }
        public int TotalUsers { get; set; }
        public int TotalCategories { get; set; }
    }

    private DashboardOverviewDto? overview;
    private bool isLoading = true;
    private string errorMessage = "";

    // SỰ THẬT KIẾN TRÚC: Chuyển sang OnAfterRenderAsync để đảm bảo Blazor đã kết nối với trình duyệt và có thể dùng JSInterop
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
        }
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        errorMessage = "";
        StateHasChanged(); // Cập nhật UI để hiện vòng xoay Loading

        try
        {
            // Lấy token từ LocalStorage
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");

            // Đính kèm token vào request nếu có
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            // Gọi API lấy dữ liệu thống kê
            overview = await Http.GetFromJsonAsync<DashboardOverviewDto>("api/Dashboard/overview");
        }
        catch (Exception ex)
        {
            errorMessage = $"Không thể kết xuất dữ liệu tổng quan: {ex.Message}";
        }
        finally
        {
            isLoading = false;
            StateHasChanged(); // Ép UI vẽ lại lần cuối khi đã có dữ liệu hoặc lỗi
        }
    }
}