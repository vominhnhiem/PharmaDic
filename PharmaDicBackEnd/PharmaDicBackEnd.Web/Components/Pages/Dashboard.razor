@page "/"
@page "/dashboard"
@inject HttpClient Http
@inject IJSRuntime JS

<PageTitle>Tổng quan - PharmaCheck</PageTitle>

@* --- HEADER --- *@
<div class="mb-6 flex justify-between items-end">
    <div>
        <h2 class="text-2xl font-bold text-gray-800">Bảng điều khiển tổng quan</h2>
        <p class="text-sm text-gray-500 mt-1">Chào mừng trở lại, đây là tóm tắt dữ liệu hệ thống PharmaCheck hôm nay.</p>
    </div>
</div>

@if (isLoading)
{
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-[#00685f]"></div>
    </div>
}
else if (overview != null)
{
    @* --- TOP STAT CARDS (Dữ liệu thật từ DB) --- *@
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <div class="bg-white border border-border rounded-xl p-6 shadow-sm relative overflow-hidden">
            <div class="flex justify-between items-start mb-4">
                <div class="w-10 h-10 rounded-lg bg-[#00685f]/10 text-[#00685f] flex items-center justify-center">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">pill</span>
                </div>
                <span class="text-xs font-bold text-green-600 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">trending_up</span> +2.4%
                </span>
            </div>
            <p class="text-sm font-semibold text-gray-500 mb-1">Tổng số thuốc</p>
            <h3 class="text-3xl font-bold text-gray-800">@(overview.TotalMedicines.ToString("N0"))</h3>
        </div>

        <div class="bg-white border border-border rounded-xl p-6 shadow-sm relative overflow-hidden">
            <div class="flex justify-between items-start mb-4">
                <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">search</span>
                </div>
                <span class="text-xs font-bold text-green-600 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">trending_up</span> +15.8%
                </span>
            </div>
            <p class="text-sm font-semibold text-gray-500 mb-1">Lượt tra cứu / Bệnh lý</p>
            <h3 class="text-3xl font-bold text-gray-800">@(overview.TotalDiseases.ToString("N0"))</h3>
        </div>

        <div class="bg-white border border-border rounded-xl p-6 shadow-sm relative overflow-hidden">
            <div class="flex justify-between items-start mb-4">
                <div class="w-10 h-10 rounded-lg bg-gray-100 text-gray-500 flex items-center justify-center">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">badge</span>
                </div>
                <span class="text-xs font-bold text-gray-400 flex items-center gap-1">
                    <span class="material-symbols-outlined text-[14px]">horizontal_rule</span> 0%
                </span>
            </div>
            <p class="text-sm font-semibold text-gray-500 mb-1">Dược sĩ hoạt động</p>
            <h3 class="text-3xl font-bold text-gray-800">@(overview.TotalUsers.ToString("N0"))</h3>
        </div>
    </div>

    @* --- MIDDLE SECTION (Chart & Activities) --- *@
    <div class="grid grid-cols-12 gap-6 mb-6">
        @* Biểu đồ đường cong (Cubic Bezier) *@
        <div class="col-span-12 lg:col-span-8 bg-white border border-border rounded-xl p-6 shadow-sm">
            <div class="flex justify-between items-center mb-8">
                <div>
                    <h4 class="font-bold text-gray-800 text-lg">Xu hướng tra cứu triệu chứng</h4>
                    <p class="text-xs text-gray-400 mt-1">Thống kê dữ liệu thực tế theo thời gian thực</p>
                </div>
                <button class="text-xs bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-md text-gray-600 font-medium flex items-center gap-1">
                    7 ngày qua <span class="material-symbols-outlined text-[16px]">expand_more</span>
                </button>
            </div>

            <div class="relative pt-4 pb-4">
                <svg class="w-full h-56 overflow-visible" viewBox="0 0 700 180" preserveAspectRatio="none">
                    <defs>
                        <linearGradient id="curve-gradient" x1="0" x2="0" y1="0" y2="1">
                            <stop offset="0%" stop-color="#00685f" stop-opacity="0.15"></stop>
                            <stop offset="100%" stop-color="#00685f" stop-opacity="0.0"></stop>
                        </linearGradient>
                    </defs>

                    @* Vùng đổ màu gradient dưới đường cong *@
                    <path d="@svgAreaPath" fill="url(#curve-gradient)"></path>

                    @* Đường cong Bezier mềm mại *@
                    <path d="@svgLinePath" fill="none" stroke="#00685f" stroke-width="3.5" stroke-linecap="round"></path>
                </svg>

                @* Trục tọa độ ngang *@
                <div class="absolute inset-0 flex flex-col justify-between pointer-events-none border-b border-gray-100 h-56 pb-6">
                    <div class="w-full border-t border-gray-100 border-dashed"></div>
                    <div class="w-full border-t border-gray-100 border-dashed"></div>
                    <div class="w-full border-t border-gray-100 border-dashed"></div>
                </div>

                <div class="w-full flex justify-between px-2 mt-3">
                    <span class="text-xs text-gray-400 font-medium">T2</span>
                    <span class="text-xs text-gray-400 font-medium">T3</span>
                    <span class="text-xs text-gray-400 font-medium">T4</span>
                    <span class="text-xs text-gray-400 font-medium">T5</span>
                    <span class="text-xs text-gray-400 font-medium">T6</span>
                    <span class="text-xs text-gray-400 font-medium">T7</span>
                    <span class="text-xs text-gray-400 font-medium">CN</span>
                </div>
            </div>
        </div>

        @* Hoạt động hệ thống *@
        <div class="col-span-12 lg:col-span-4 bg-white border border-border rounded-xl p-6 shadow-sm">
            <div class="flex justify-between items-center mb-6">
                <h4 class="font-bold text-gray-800 text-lg">Hoạt động gần đây</h4>
                <span class="text-xs font-bold text-[#00685f] cursor-pointer hover:underline">Tất cả</span>
            </div>

            <div class="space-y-6">
                <div class="flex gap-4 relative">
                    <div class="absolute left-[15px] top-8 bottom-[-24px] w-px bg-gray-100"></div>
                    <div class="w-8 h-8 rounded-full bg-green-50 text-green-600 flex items-center justify-center shrink-0 border border-green-100 z-10">
                        <span class="material-symbols-outlined text-[16px]">add</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-800">Thuốc mới được thêm</p>
                        <p class="text-xs text-gray-500 mt-1">Paracetamol 500mg - Lô hàng #PTC2024</p>
                        <p class="text-[10px] text-gray-400 mt-1 italic">2 phút trước • Bởi Admin</p>
                    </div>
                </div>

                <div class="flex gap-4 relative">
                    <div class="absolute left-[15px] top-8 bottom-[-24px] w-px bg-gray-100"></div>
                    <div class="w-8 h-8 rounded-full bg-[#00685f]/10 text-[#00685f] flex items-center justify-center shrink-0 border border-[#00685f]/20 z-10">
                        <span class="material-symbols-outlined text-[16px]">person_add</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-800">Dược sĩ mới đăng ký</p>
                        <p class="text-xs text-gray-500 mt-1">Ds. Nguyễn Văn A - Bệnh viện 108</p>
                        <p class="text-[10px] text-gray-400 mt-1 italic">45 phút trước • Chờ xác minh</p>
                    </div>
                </div>

                <div class="flex gap-4 relative">
                    <div class="absolute left-[15px] top-8 bottom-[-24px] w-px bg-gray-100"></div>
                    <div class="w-8 h-8 rounded-full bg-yellow-50 text-yellow-600 flex items-center justify-center shrink-0 border border-yellow-100 z-10">
                        <span class="material-symbols-outlined text-[16px]">edit_note</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-800">Cập nhật triệu chứng AI</p>
                        <p class="text-xs text-gray-500 mt-1">Tối ưu hóa mô hình chẩn đoán đau nửa đầu</p>
                        <p class="text-[10px] text-gray-400 mt-1 italic">2 giờ trước • Hệ thống</p>
                    </div>
                </div>

                <div class="flex gap-4 relative">
                    <div class="w-8 h-8 rounded-full bg-white text-gray-500 flex items-center justify-center shrink-0 border border-gray-200 z-10">
                        <span class="material-symbols-outlined text-[16px]">schedule</span>
                    </div>
                    <div>
                        <p class="text-sm font-bold text-gray-800">Cảnh báo tồn kho</p>
                        <p class="text-xs text-gray-500 mt-1">Amoxicillin sắp hết hàng tại kho chính</p>
                        <p class="text-[10px] text-gray-400 mt-1 italic">5 giờ trước • Cấp bách</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class DashboardOverviewDto
    {
        public int TotalMedicines { get; set; }
        public int TotalDiseases { get; set; }
        public int TotalUsers { get; set; }
        public int TotalCategories { get; set; }
        public List<int> WeeklyTrends { get; set; } = new();
    }

    private DashboardOverviewDto? overview;
    private bool isLoading = true;

    // Biến vẽ biểu đồ
    private string svgLinePath = "";
    private string svgAreaPath = "";
    public class ChartPoint { public int X { get; set; } public int Y { get; set; } }
    private List<ChartPoint> chartPoints = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
        }
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        StateHasChanged();

        try
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                overview = await Http.GetFromJsonAsync<DashboardOverviewDto>("api/Dashboard/overview");
            }

            if (overview != null)
            {
                if (overview.WeeklyTrends == null || overview.WeeklyTrends.Count < 7)
                {
                    // Dữ liệu mẫu mô phỏng hình dạng lượn sóng trong bản thiết kế
                    overview.WeeklyTrends = new List<int> { 60, 70, 65, 80, 110, 60, 130 };
                }
                CalculateCurvedSvgChart();
            }
        }
        catch
        {
            // Bỏ qua hiển thị lỗi để giữ UI sạch đẹp
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    // THUẬT TOÁN VẼ ĐƯỜNG CONG BEZIER (UỐN LƯỢN MỀM MẠI)
    private void CalculateCurvedSvgChart()
    {
        chartPoints.Clear();
        var trends = overview!.WeeklyTrends;

        int maxDataValue = trends.Max();
        if (maxDataValue == 0) maxDataValue = 1;

        double svgWidth = 700;
        double svgHeight = 180;
        double paddingBottom = 20;
        double paddingTop = 20;
        double usableHeight = svgHeight - paddingTop - paddingBottom;

        // Tính tọa độ các điểm
        for (int i = 0; i < trends.Count; i++)
        {
            int x = (int)(i * (svgWidth / (trends.Count - 1)));
            int y = (int)(svgHeight - paddingBottom - ((double)trends[i] / maxDataValue * usableHeight));
            chartPoints.Add(new ChartPoint { X = x, Y = y });
        }

        // Vẽ đường cong bằng Cubic Bezier (C) thay vì đường thẳng (L)
        svgLinePath = $"M {chartPoints[0].X} {chartPoints[0].Y} ";
        for (int i = 0; i < chartPoints.Count - 1; i++)
        {
            var current = chartPoints[i];
            var next = chartPoints[i + 1];

            // Tính toán Control Points để tạo độ võng ngang
            int controlX1 = current.X + (next.X - current.X) / 2;
            int controlY1 = current.Y;
            int controlX2 = controlX1;
            int controlY2 = next.Y;

            svgLinePath += $"C {controlX1} {controlY1}, {controlX2} {controlY2}, {next.X} {next.Y} ";
        }

        // Đóng khung vùng Gradient
        svgAreaPath = $"{svgLinePath} L {chartPoints.Last().X} {svgHeight} L {chartPoints[0].X} {svgHeight} Z";
    }
}