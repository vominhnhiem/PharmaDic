@* Khai báo định tuyến trang này làm trang chủ mặc định *@
@page "/"
@page "/dashboard"
@inject HttpClient Http
@using Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage
@inject HttpClient Http
@inject ProtectedLocalStorage ProtectedLocalStore

<PageTitle>Tổng quan - PharmaCheck</PageTitle>

<div class="mb-stack-lg flex justify-between items-end">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-primary">Bảng điều khiển tổng quan</h2>
        <p class="font-body-md text-body-md text-on-surface-variant mt-1">Chào mừng trở lại, đây là tóm tắt dữ liệu hệ thống PharmaCheck hôm nay.</p>
    </div>
    <div class="flex gap-3">
        <button class="flex items-center gap-2 px-4 py-2 bg-primary text-white font-label-md rounded hover:shadow-lg transition-all" @onclick="LoadDashboardData">
            <span class="material-symbols-outlined text-[18px]">refresh</span>
            Làm mới dữ liệu
        </button>
    </div>
</div>

@if (isLoading)
{
    <div class="flex justify-center items-center py-20">
        <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-primary"></div>
        <span class="ml-3 text-lg text-on-surface-variant">Đang đồng bộ dữ liệu từ máy chủ...</span>
    </div>
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    @* BẮT BUỘC HIỂN THỊ: Lỗi gì cũng phải hiện ra ở đây *@
    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded-lg relative mb-6" role="alert">
        <strong class="font-bold">Hệ thống phát hiện lỗi:</strong>
        <span class="block sm:inline"> @errorMessage</span>
    </div>
}
else if (overview != null)
{
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-stack-lg">
        @* Thẻ 1: Tổng số thuốc *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="p-2 bg-primary/10 rounded w-fit">
                <span class="material-symbols-outlined text-primary" style="font-variation-settings: 'FILL' 1;">pill</span>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tổng số thuốc trong từ điển</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalMedicines</h3>
            </div>
        </div>

        @* Thẻ 2: Bệnh lý *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="p-2 bg-red-100 text-red-600 rounded w-fit">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">coronavirus</span>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Bệnh lý & Triệu chứng</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalDiseases</h3>
            </div>
        </div>

        @* Thẻ 3: Tài khoản *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="p-2 bg-blue-100 text-blue-600 rounded w-fit">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">medical_information</span>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Tài khoản hoạt động</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalUsers</h3>
            </div>
        </div>

        @* Thẻ 4: Danh mục *@
        <div class="bg-surface border border-border rounded-lg p-stack-md medical-shadow flex flex-col justify-between hover:-translate-y-0.5 transition-all duration-300">
            <div class="p-2 bg-yellow-100 text-yellow-600 rounded w-fit">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">category</span>
            </div>
            <div class="mt-4">
                <p class="font-label-md text-label-md text-on-surface-variant">Danh mục phân loại</p>
                <h3 class="font-headline-md text-headline-md mt-1">@overview.TotalCategories</h3>
            </div>
        </div>
    </div>
}
else
{
    @* ĐƯỜNG LÙI AN TOÀN: Nếu lỗi không xác định khiến cả 2 biến trên đều null *@
    <div class="p-4 bg-yellow-100 text-yellow-800 rounded-lg">
        Hệ thống đang ở trạng thái rỗng. Không thể nạp dữ liệu cấu trúc tổng quan.
    </div>
}

@code {
    public class DashboardOverviewDto
    {
        public int TotalMedicines { get; set; }
        public int TotalDiseases { get; set; }
        public int TotalUsers { get; set; }
        public int TotalCategories { get; set; }
    }

    private DashboardOverviewDto? overview;
    private bool isLoading = true;
    private string errorMessage = "";

    protected override void OnInitialized()
    {
        isLoading = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
            StateHasChanged();
        }
    }

    private async Task LoadDashboardData()
    {
        isLoading = true;
        errorMessage = "";
        await InvokeAsync(StateHasChanged); // Ép vẽ spinner ngay lập tức

        try
        {
            Console.WriteLine("[HỘP ĐEN] 1. Đang cố gắng móc Token từ LocalStorage...");
            var tokenResult = await ProtectedLocalStore.GetAsync<string>("authToken");
            var token = tokenResult.Success ? tokenResult.Value : null;
            Console.WriteLine($"[HỘP ĐEN] 2. Đã móc Token xong. Token có tồn tại không: {!string.IsNullOrEmpty(token)}");

            if (string.IsNullOrEmpty(token))
            {
                errorMessage = "Không tìm thấy Token. Vui lòng đăng nhập lại.";
                return;
            }

            Http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            Console.WriteLine("[HỘP ĐEN] 3. Bắt đầu bắn request sang Backend (apiservice)...");

            // Ép thời gian chờ tối đa 10 giây để không bị treo vĩnh viễn
            using var cts = new CancellationTokenSource(TimeSpan.FromSeconds(10));
            overview = await Http.GetFromJsonAsync<DashboardOverviewDto>("api/Dashboard/overview", cts.Token);

            Console.WriteLine("[HỘP ĐEN] 4. Đã nhận dữ liệu thành công từ Backend!");
        }
        catch (TaskCanceledException)
        {
            errorMessage = "Đã quá thời gian chờ (10 giây). Backend không phản hồi. Aspire có thể đang không tìm thấy tên 'apiservice'.";
            Console.WriteLine("[HỘP ĐEN LỖI] Timeout 10 giây!");
        }
        catch (HttpRequestException ex)
        {
            errorMessage = $"Bị từ chối tại cổng Server: {ex.StatusCode} - {ex.Message}";
            Console.WriteLine($"[HỘP ĐEN LỖI] HTTP: {ex.Message}");
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi nội bộ Blazor: {ex.Message}";
            Console.WriteLine($"[HỘP ĐEN LỖI] EXCEPTION: {ex.Message}");
        }
        finally
        {
            Console.WriteLine("[HỘP ĐEN] 5. Kết thúc luồng, chuẩn bị tắt Spinner.");
            isLoading = false;

            // CÚ "ĐẤM" QUYẾT ĐỊNH: Ép Blazor phải vẽ lại giao diện dù nó đang chạy trên Thread nào
            await InvokeAsync(StateHasChanged);
        }
    }
}